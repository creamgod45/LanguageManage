<idea-plugin>
    <dependencies>
        <module name="intellij.platform.frontend"/>
        <module name="LanguageManage.shared"/>
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
                parentId="tools"
                id="cg.creamgod45.localization.LanguageManagerSettings"
                instance="cg.creamgod45.settings.LanguageManagerSettingsConfigurable"
                bundle="messages.LanguageManagerFrontendBundle"
                key="settings.display.name"/>
        <toolWindow
                id="Language Manager"
                anchor="right"
                factoryClass="cg.creamgod45.toolWindow.LanguageManagerToolWindowFactory"
                icon="cg.creamgod45.LanguageManagerIcons.ToolWindow"/>
        <notificationGroup id="LanguageManager" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="cg.creamgod45.localization.ProjectViewGroup"
               class="cg.creamgod45.localization.ui.LanguageManagerProjectViewActionGroup"
               popup="true">
            <action id="cg.creamgod45.localization.ExcludeFoldersFromActiveScheme"
                    class="cg.creamgod45.localization.ui.ExcludeFoldersFromActiveSchemeAction"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
